# Aiven PostgreSQL Connection
# Get these values from Aiven Console > Your Service > Overview tab
DB_HOST=your-service-name.aivencloud.com
DB_PORT=12345
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your-password-here
DB_SSL=require

# Full connection string (alternative to individual fields above)
DATABASE_URL=postgresql://avnadmin:your-password-here@your-service-name.aivencloud.com:12345/defaultdb?sslmode=require
