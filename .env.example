# Aiven PostgreSQL Connection
# Get these values from Aiven Console > Your Service > Overview tab
DB_HOST=your-service-name.aivencloud.com
DB_PORT=12345
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your-password-here
DB_SSL=require

# Full async URL for SQLAlchemy backend (asyncpg format)
DATABASE_URL=postgresql+asyncpg://avnadmin:your-password-here@your-service-name.aivencloud.com:12345/defaultdb?ssl=require

# Secret key for JWT token signing (generate a strong random string)
SECRET_KEY=your-secret-key-here

# Resend API Key for emails
RESEND_API_KEY=re_your_key_here

# Resend AI Service Keys
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-api-key

# Resend Webhook Secret for Inbound Emails
RESEND_WEBHOOK_SECRET=whsec_your_secret_here

# chromadb cloud setup"
CHROMA_API_KEY=your-api-key-here
CHROMA_TENANT=your-tenant-here
CHROMA_DATABASE=your-database-here

# AWS S3 Data Ingestion Credentials
S3_ACCESS_KEY=your_aws_access_key
S3_SECRET_ACCESS_KEY=your_aws_secret_key
REGION=your_aws_region
S3_BUCKET_NAME=your_s3_bucket_name
